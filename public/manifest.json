{
  "name": "\u7535\u6893\u64ad\u653e\u5668 - \u7b2c\u4e09\u65b9 Bilibili \u97f3\u9891\u64ad\u653e\u5668",
  "version": "2.0.2",
  "description": "azusa-player: \u7b2c\u4e09\u65b9 Bilibili \u97f3\u9891\u64ad\u653e\u5668 / A 3rd party Bilibili audio player.",
  "manifest_version": 3,
  "background": {
    "service_worker": "src/serviceworker/index.ts"
  },
  "options_page": "src/popup/index.html",
  "action": {
    "default_title": "Azusa Player",
    "default_icon": {
      "16": "icons/logo2-128.png",
      "128": "icons/logo2-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "src/scripts/contentscript/index.ts"
      ]
    }
  ],
  "icons": {
    "128": "icons/logo2-128.png"
  },
  "permissions": [
    "declarativeNetRequest",
    "scripting",
    "storage",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "*://*.acgvideo.com/*",
    "*://*.bilivideo.com/*",
    "*://*.bilibili.com/*",
    "*://*.hdslb.com/*",
    "*://*.cgvideo.com/*",
    "*://*.y.qq.com/*",
    "*://*.bilivideo.cn/*",
    "*://*.akamaized.net/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
